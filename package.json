{
  "name": "security-search",
  "version": "1.0.0",
  "description": "Browser extension to protect users from scam sites in search results",
  "scripts": {
    "test": "jest --forceExit",
    "test:unit": "jest tests/background.test.js tests/popup.test.js --forceExit",
    "test:e2e": "playwright test tests/extension.spec.js",
    "test:e2e:ui": "playwright test tests/extension.spec.js --ui",
    "test:e2e:headed": "playwright test tests/extension.spec.js --headed",
    "test:all": "npm run test:unit && npm run test:e2e",
    "lint": "eslint .",
    "build": "echo 'Extension ready for loading'"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "jest": "^29.7.0",
    "eslint": "^8.57.0"
  },
  "keywords": ["browser-extension", "security", "scam-detection", "web3"],
  "license": "MIT"
}
